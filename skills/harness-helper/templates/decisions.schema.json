{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "harness-helper decisions",
  "description": "grill 拷问得出的五子系统决策。generate.mjs 读取此结构生成 harness 产物。",
  "type": "object",
  "required": ["instructions", "state", "verification", "scope", "lifecycle"],
  "properties": {
    "instructions": {
      "type": "object",
      "required": ["agentFile", "purpose"],
      "properties": {
        "agentFile": { "type": "string", "enum": ["AGENTS.md", "CLAUDE.md"] },
        "purpose": { "type": "string", "description": "项目用途一句话" },
        "startupSteps": {
          "type": "array",
          "items": { "type": "string" },
          "description": "额外的启动步骤（可选，会并入默认启动流程）"
        }
      }
    },
    "state": {
      "type": "object",
      "required": ["features"],
      "properties": {
        "layout": {
          "type": "string",
          "enum": ["root", "versioned"],
          "default": "root",
          "description": "root=状态文件放项目根目录（单人/小项目）；versioned=放 .harness/versions/<版本>/，按版本维度组织（团队/有发版节奏）"
        },
        "versionSource": {
          "type": "object",
          "description": "layout=versioned 时，如何解析当前版本号。command 是一条打印版本号到 stdout 的 shell；generate.mjs 与 init.sh 共用它，保证两边同步。命令由项目自身决定（如读版本文件、清单字段或 VCS 标签）。",
          "properties": {
            "command": { "type": "string", "description": "打印版本号到 stdout 的 shell 命令，例如 cat VERSION 或 node -p \"require('./package.json').version\"" },
            "label": { "type": "string", "description": "版本来源说明，例如 VERSION 文件、清单的 version 字段" }
          }
        },
        "features": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "name", "description", "status"],
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "description": { "type": "string" },
              "owner": { "type": "string", "description": "collaboration.mode=team 时，该功能的负责人（git user.name）；一个工单只由一人维护其条目，减少合并冲突" },
              "dependencies": { "type": "array", "items": { "type": "string" } },
              "status": { "type": "string", "enum": ["not-started", "in-progress", "pass", "fail"] },
              "evidence": { "type": "string" }
            }
          }
        }
      }
    },
    "verification": {
      "type": "object",
      "required": ["commands"],
      "properties": {
        "commands": {
          "type": "array",
          "items": { "type": "string" },
          "description": "init.sh 里依次执行的验证命令"
        }
      }
    },
    "scope": {
      "type": "object",
      "properties": {
        "oneFeatureAtATime": { "type": "boolean", "default": true },
        "extraRules": { "type": "array", "items": { "type": "string" } },
        "doneCriteria": {
          "type": "array",
          "items": { "type": "string" },
          "description": "完成的定义清单"
        }
      }
    },
    "lifecycle": {
      "type": "object",
      "properties": {
        "useHandoff": { "type": "boolean", "default": true },
        "endOfSessionSteps": { "type": "array", "items": { "type": "string" } }
      }
    },
    "collaboration": {
      "type": "object",
      "description": "团队协作策略。决定 progress.md / session-handoff.md 是否按 git 作者分节并用 merge=union 合并，以及 feature_list 是否带 owner 字段。",
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["solo", "team"],
          "default": "solo",
          "description": "solo=单人，状态文件普通格式；team=多人，progress/handoff 用 ## @<git user.name> 分节 + merge=union 追加式合并，feature_list 加 owner 字段"
        }
      }
    }
  }
}
